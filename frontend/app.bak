@app.get("/results/<path:filename>")
@login_required
def serve_result_video(filename: str) -> Response:
    return send_from_directory(OUTPUTS_DIR, filename)


@app.get("/job-sources/<job_id>")
@login_required
def serve_test_job_source(job_id: str) -> Response:
    job = get_job(job_id)
    if job is None:
        abort(404)

    source_video = job.get("source_video")
    if not source_video:
        abort(404)

    source_path = Path(str(source_video))
    if not source_path.exists() or source_path.suffix.lower() not in ALLOWED_VIDEO_EXTENSIONS:
        abort(404)

    return send_file(source_path, conditional=True)


@app.get("/job-previews/<job_id>.jpg")
@login_required
def serve_test_job_preview(job_id: str) -> Response:
    job = get_job(job_id)
    if job is None:
        abort(404)

    preview_path = preview_path_for_job(job_id)
    if preview_path.exists():
        response = send_file(preview_path, mimetype="image/jpeg", conditional=False)
        response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate, max-age=0"
        return response

    status = str(job.get("status", "queued"))
    if status == "running":
        title = "Dang phan tich video"
    elif status == "completed":
        title = "Da hoan tat xu ly"
    elif status == "failed":
        title = "Khong tao duoc preview"
    else:
        title = "Dang cho den luot xu ly"

    detail = str(job.get("message", ""))
    response = Response(build_placeholder_frame(title, detail), mimetype="image/jpeg")
    response.headers["Cache-Control"] = "no-store, no-cache, must-revalidate, max-age=0"
    return response


@app.get("/api/session")
@login_required
def api_session() -> Response:
    return jsonify({"ok": True, "user": get_current_user()})


@app.get("/api/dashboard")
@login_required
def api_dashboard() -> Response:
    return jsonify({"ok": True, "stats": get_dashboard_stats()})


@app.get("/api/users")
@admin_required
def api_list_users() -> Response:
    return jsonify({"ok": True, "users": list_users()})


@app.post("/api/users")
@admin_required
def api_create_user() -> Response:
    payload = request.get_json(silent=True) or {}
    try:
        user_payload = validate_user_payload(payload, creating=True)
        created = create_user(user_payload)
        return jsonify({"ok": True, "user": created}), 201
    except ValueError as exc:
        return json_error(str(exc), 400)
    except sqlite3.IntegrityError:
        return json_error("Tên đăng nhập đã tồn tại.", 409)


@app.put("/api/users/<int:user_id>")
@admin_required
def api_update_user(user_id: int) -> Response:
    payload = request.get_json(silent=True) or {}
    existing = get_user_record_by_id(user_id)
    if existing is None:
        return json_error("Không tìm thấy người dùng.", 404)

    try:
        user_payload = validate_user_payload(payload, creating=False)
        if "password_hash" not in user_payload and not payload.get("password"):
            user_payload.pop("password_hash", None)

        if existing["role"] == "admin" and user_payload["role"] != "admin" and count_admin_users() <= 1:
            return json_error("Cần giữ lại ít nhất một tài khoản admin.", 400)

        updated = update_user(user_id, user_payload)
        if updated is None:
            return json_error("Không tìm thấy người dùng.", 404)
        return jsonify({"ok": True, "user": updated})
    except ValueError as exc:
        return json_error(str(exc), 400)
    except sqlite3.IntegrityError:
        return json_error("Tên đăng nhập đã tồn tại.", 409)


@app.delete("/api/users/<int:user_id>")
@admin_required
def api_delete_user(user_id: int) -> Response:
    current_user = get_current_user()
    target = get_user_record_by_id(user_id)
    if target is None:
        return json_error("Không tìm thấy người dùng.", 404)
    if current_user is not None and current_user["id"] == user_id:
        return json_error("Không thể tự xóa chính mình.", 400)
    if target["role"] == "admin" and count_admin_users() <= 1:
        return json_error("Cần giữ lại ít nhất một tài khoản admin.", 400)

    deleted = delete_user(user_id)
    if not deleted:
        return json_error("Không thể xóa người dùng.", 400)
    return jsonify({"ok": True})


@app.get("/api/cameras")
@login_required
def api_list_cameras() -> Response:
    return jsonify({"ok": True, "cameras": list_cameras()})


@app.post("/api/cameras")
@login_required
def api_create_camera() -> Response:
    payload = request.get_json(silent=True) or {}
    try:
        camera_payload = validate_camera_payload(payload)
        created = create_camera(camera_payload)
        return jsonify({"ok": True, "camera": created}), 201
    except ValueError as exc:
        return json_error(str(exc), 400)
    except sqlite3.IntegrityError:
        return json_error("Tên camera đã tồn tại.", 409)


@app.put("/api/cameras/<int:camera_id>")
@login_required
def api_update_camera(camera_id: int) -> Response:
    payload = request.get_json(silent=True) or {}
    if get_camera(camera_id) is None:
        return json_error("Không tìm thấy camera.", 404)

    try:
        camera_payload = validate_camera_payload(payload)
        updated = update_camera(camera_id, camera_payload)
        if updated is None:
            return json_error("Không tìm thấy camera.", 404)
        return jsonify({"ok": True, "camera": updated})
    except ValueError as exc:
        return json_error(str(exc), 400)
    except sqlite3.IntegrityError:
        return json_error("Tên camera đã tồn tại.", 409)


@app.delete("/api/cameras/<int:camera_id>")
@login_required
def api_delete_camera(camera_id: int) -> Response:
    deleted = delete_camera(camera_id)
    if not deleted:
        return json_error("Không tìm thấy camera.", 404)
    return jsonify({"ok": True})


@app.get("/api/cameras/<int:camera_id>/snapshot")
@login_required
def api_camera_snapshot(camera_id: int) -> Response:
    camera = get_camera(camera_id)
    if camera is None:
        return Response(build_placeholder_frame("Không tìm thấy camera."), mimetype="image/jpeg")

    capture_source = normalize_capture_source(camera["stream_source"])
    if capture_source is None:
        return Response(
            build_placeholder_frame("Chưa cấu hình nguồn camera.", camera["name"]),
            mimetype="image/jpeg",
        )

    capture = cv2.VideoCapture(capture_source)
    try:
        success, frame = capture.read()
    finally:
        capture.release()

    if not success or frame is None:
        detail = camera["stream_source"] or "Nguồn camera trống."
        return Response(
            build_placeholder_frame("Không đọc được hình ảnh camera.", detail),
            mimetype="image/jpeg",
        )

    prepared = prepare_snapshot_frame(frame, camera)
    return Response(encode_jpeg(prepared), mimetype="image/jpeg")


@app.post("/api/test-jobs")
@login_required
def api_create_test_job() -> Response:
    job_id = uuid.uuid4().hex
    camera = None
    camera_id_text = request.form.get("camera_id", "").strip()
    if camera_id_text:
        camera = get_camera(int(camera_id_text))
        if camera is None:
            return json_error("Camera duoc chon khong ton tai.", 404)

    upload_file = request.files.get("video_file")
    local_path_text = request.form.get("local_path", "").strip()

    if upload_file is not None and upload_file.filename:
        extension = Path(upload_file.filename).suffix.lower()
        if extension not in ALLOWED_VIDEO_EXTENSIONS:
            return json_error("Dinh dang video khong duoc ho tro.", 400)
        safe_name = secure_filename(upload_file.filename)
        input_path = INPUTS_DIR / f"{job_id}_{safe_name}"
        upload_file.save(input_path)
    elif local_path_text:
        input_path = resolve_path(local_path_text)
        if not input_path.exists():
            return json_error("Duong dan video local khong ton tai.", 400)
        if input_path.suffix.lower() not in ALLOWED_VIDEO_EXTENSIONS:
            return json_error("Dinh dang video khong duoc ho tro.", 400)
    else:
        return json_error("Hay chon file upload hoac nhap duong dan local.", 400)

    try:
        test_settings = build_test_settings(request.form, camera)
    except ValueError as exc:
        return json_error(str(exc), 400)

    output_filename = f"{job_id}_result.mp4"
    submitted_at = time.time()
    set_job(
        job_id,
        status="queued",
        message="Da nhan yeu cau. Job se duoc xu ly theo hang doi.",
        error=None,
        output_filename=None,
        summary=None,
        source_video=str(input_path),
        submitted_at=submitted_at,
        progress={
            "phase": "queued",
            "processed_frames": 0,
            "source_total_frames": None,
            "progress_percent": 0.0,
            "elapsed_seconds": 0.0,
            "latest_status": "Dang cho den luot xu ly...",
        },
    )
    executor.submit(
        run_detection_job,
        job_id,
        str(input_path),
        output_filename,
        test_settings,
    )

    return jsonify({"ok": True, "job": public_job(get_job(job_id) or {"id": job_id})}), 202


@app.get("/api/test-jobs/<job_id>")
@login_required
def api_get_test_job(job_id: str) -> Response:
    job = get_job(job_id)
    if job is None:
        return json_error("Không tìm thấy job kiểm tra.", 404)
    return jsonify({"ok": True, "job": public_job(job)})


@app.errorhandler(403)
def handle_forbidden(_error: Exception) -> Response:
    return render_template(
        "error.html",
        page="error",
        status_code=403,
        title="Không có quyền truy cập",
        message="Tài khoản hiện tại không được phép mở trang này.",
    ), 403


@app.errorhandler(404)
def handle_not_found(_error: Exception) -> Response:
    return render_template(
        "error.html",
        page="error",
        status_code=404,
        title="Không tìm thấy nội dung",
        message="Đường dẫn bạn mở không tồn tại trong web portal.",
    ), 404


@app.errorhandler(413)
def handle_large_upload(_error: Exception) -> Response:
    return render_template(
        "error.html",
        page="error",
        status_code=413,
        title="File quá lớn",
        message="Video upload vượt quá giới hạn dung lượng cho phép.",
    ), 413


if __name__ == "__main__":
    app.run(host="127.0.0.1", port=5000, debug=False)

